---
import Analytics from '@vercel/analytics/astro';
import logoImg from '../assets/logo.png';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'BLOQ Media | Shaping Tech Narratives in Southeast Asia',
  description =
    'BLOQ Media is a news organization and digital marketing agency specializing in tech and blockchain in Southeast Asia. We craft authoritative reporting, strategic content, and digital marketing for the region\'s most innovative companies.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = Astro.url.href;
const absoluteOgImage = new URL(ogImage, Astro.site).href;
const absoluteLogo = new URL(logoImg.src, Astro.site).href;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'NewsMediaOrganization'],
  name: 'BLOQ Media',
  url: 'https://bloq.media',
  logo: absoluteLogo,
  description:
    'BLOQ Media is a news organization and digital marketing agency specializing in tech and blockchain in Southeast Asia.',
  email: 'degen@bloq.media',
  areaServed: 'Southeast Asia',
  sameAs: [
    'https://x.com/_BLOQMedia',
    'https://www.linkedin.com/company/bloq-media/',
    'https://medium.com/@bloqmedia',
  ],
  knowsAbout: ['Blockchain', 'Technology', 'Digital Marketing', 'Content Strategy', 'Fintech', 'Web3'],
  publishingPrinciples: 'https://bloq.media',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'BLOQ Media',
  url: 'https://bloq.media',
  description: 'News organization and digital marketing agency for tech and blockchain in Southeast Asia',
  publisher: {
    '@type': 'Organization',
    name: 'BLOQ Media',
    logo: {
      '@type': 'ImageObject',
      url: absoluteLogo,
    },
  },
};
---

<!doctype html>
<html lang="en" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1A3C8F" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="author" content="BLOQ Media" />
    <meta name="keywords" content="blockchain, Southeast Asia, tech media, digital marketing, fintech, Web3, content strategy, Singapore, Thailand, Philippines" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="BLOQ Media" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="BLOQ Media — Shaping Tech Narratives in Southeast Asia" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@_BLOQMedia" />
    <meta name="twitter:creator" content="@_BLOQMedia" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content="BLOQ Media — Shaping Tech Narratives in Southeast Asia" />

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts — only the weights actually used (400/500/600/700); loaded
         non-render-blocking so first paint isn't gated on a third-party CSS
         round trip (important on mobile networks). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.onload=null;this.setAttribute('media','all')"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Gate scroll-animation hidden state: elements stay visible if JS never runs -->
    <script is:inline>document.documentElement.classList.add('js-ready');</script>
  </head>
  <body class="font-sans antialiased text-gray-900 bg-white">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[60] focus:bg-bloq-navy focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold"
    >
      Skip to content
    </a>
    <slot />
    <Analytics />

    <script>
      // Scroll-triggered entrance animations
      const animateObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            // After the entrance completes, clear stagger delay so hover
            // transitions on cards aren't delayed on subsequent interactions.
            setTimeout(() => {
              (entry.target as HTMLElement).style.transitionDelay = '';
            }, 1000);
            animateObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
      );
      document.querySelectorAll('[data-animate]').forEach((el) => animateObserver.observe(el));
    </script>
  </body>
</html>
