---
interface Reason {
  title: string;
  description: string;
  icon: string;
}

const reasons: Reason[] = [
  {
    title: 'Regional Expertise',
    description: "We know the markets, the key players, and the cultural context across Thailand, Singapore, Vietnam, the Philippines, and beyond.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>`,
  },
  {
    title: 'Blockchain Focus',
    description: 'From DeFi protocols to Web3 infrastructure, we make blockchain legible — for founders, investors, and the broader public alike.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
    </svg>`,
  },
  {
    title: 'Results-Driven',
    description: 'Measurable lifts in brand awareness, organic reach, and inbound leads. We focus on outcomes, not outputs.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
    </svg>`,
  },
];
---

<section id="why" class="py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center max-w-3xl mx-auto mb-16">
      <p class="text-bloq-blue text-sm font-semibold uppercase tracking-widest mb-4">Why Choose Us</p>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Why BLOQ Media?</h2>
      <p class="text-lg text-gray-500 leading-relaxed">
        We've spent years embedded in Southeast Asia's tech and blockchain ecosystem — covering the stories others miss,
        reaching the audiences others can't, and making complex ideas legible for the people who need to understand them.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {reasons.map((reason) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl hover:shadow-bloq-navy/8 border border-gray-100 hover:border-bloq-blue/20 transition-all duration-300 group">
          <div class="w-14 h-14 bg-bloq-navy rounded-xl flex items-center justify-center text-white mb-6 group-hover:bg-bloq-blue transition-colors duration-300">
            <Fragment set:html={reason.icon} />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{reason.title}</h3>
          <p class="text-gray-500 leading-relaxed">{reason.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
