---
---

<section class="relative min-h-screen bg-gradient-to-br from-bloq-dark via-bloq-navy to-bloq-navy flex items-center pt-20 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 py-28 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <div>
        <div class="inline-flex items-center gap-2 bg-bloq-blue/20 border border-bloq-blue/30 text-bloq-blue text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-8">
          <span class="w-1.5 h-1.5 bg-bloq-blue rounded-full"></span>
          News &amp; Media
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] mb-6">
          Shaping Tech Narratives in
          <span class="text-bloq-blue">Southeast Asia</span>
        </h1>

        <p class="text-xl text-white/65 mb-10 leading-relaxed">
          Authoritative news coverage and strategic content for the tech and blockchain companies defining Southeast Asia's future.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#contact"
            class="inline-flex items-center justify-center bg-bloq-blue text-white px-8 py-4 rounded-xl font-semibold text-base hover:bg-opacity-90 active:scale-[0.97] transition-all duration-200 shadow-lg shadow-bloq-blue/25"
          >
            Get in Touch
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="#about"
            class="inline-flex items-center justify-center border border-white/25 text-white px-8 py-4 rounded-xl font-semibold text-base hover:bg-white/10 active:scale-[0.97] transition-all duration-200"
          >
            Learn More
          </a>
        </div>
      </div>

      <div class="hidden lg:flex items-center justify-center">
        <svg
          id="sea-map"
          class="w-full opacity-0 transition-opacity duration-1000"
          style="height: 520px;"
          aria-hidden="true"
        ></svg>
      </div>

    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white/5 to-transparent pointer-events-none"></div>
</section>

<script>
  import * as d3 from 'd3';
  import { feature } from 'topojson-client';
  // @ts-ignore — world-atlas ships plain JSON, no type declarations needed
  import worldData from 'world-atlas/countries-50m.json';

  // ISO 3166-1 numeric codes for Southeast Asian countries
  const SEA_IDS = new Set([96, 104, 116, 360, 418, 458, 608, 626, 702, 704, 764]);

  const svgEl = document.getElementById('sea-map') as SVGSVGElement | null;
  if (!svgEl) throw new Error('Missing #sea-map');

  const width = svgEl.clientWidth;
  const height = svgEl.clientHeight;

  const allCountries = feature(worldData, worldData.objects.countries) as any;
  const seaCollection: GeoJSON.FeatureCollection = {
    type: 'FeatureCollection',
    features: allCountries.features.filter((f: any) => SEA_IDS.has(+f.id)),
  };

  const projection = d3.geoMercator().fitExtent(
    [[24, 24], [width - 24, height - 24]],
    seaCollection
  );
  const path = d3.geoPath().projection(projection);

  const svg = d3.select(svgEl);

  // Glow filter
  const defs = svg.append('defs');
  const filter = defs.append('filter').attr('id', 'map-glow').attr('x', '-20%').attr('y', '-20%').attr('width', '140%').attr('height', '140%');
  filter.append('feGaussianBlur').attr('in', 'SourceGraphic').attr('stdDeviation', '3').attr('result', 'blur');
  const merge = filter.append('feMerge');
  merge.append('feMergeNode').attr('in', 'blur');
  merge.append('feMergeNode').attr('in', 'SourceGraphic');

  // Country fills
  svg.append('g')
    .selectAll<SVGPathElement, GeoJSON.Feature>('path')
    .data(seaCollection.features)
    .join('path')
    .attr('d', path as any)
    .attr('fill', 'rgba(41,171,226,0.08)')
    .attr('stroke', 'rgba(41,171,226,0.7)')
    .attr('stroke-width', 1.2)
    .attr('stroke-linejoin', 'round')
    .attr('filter', 'url(#map-glow)');

  // Major city dots
  const cities = [
    { name: 'Singapore',       coords: [103.82, 1.35]   as [number,number] },
    { name: 'Bangkok',         coords: [100.52, 13.75]  as [number,number] },
    { name: 'Jakarta',         coords: [106.85, -6.21]  as [number,number] },
    { name: 'Manila',          coords: [120.98, 14.60]  as [number,number] },
    { name: 'Ho Chi Minh',     coords: [106.66, 10.78]  as [number,number] },
    { name: 'Kuala Lumpur',    coords: [101.69, 3.14]   as [number,number] },
    { name: 'Yangon',          coords: [96.17,  16.87]  as [number,number] },
  ];

  const cityG = svg.append('g');
  cities.forEach(({ name, coords }) => {
    const [x, y] = projection(coords) ?? [0, 0];

    // Outer pulse ring
    cityG.append('circle')
      .attr('cx', x).attr('cy', y).attr('r', 6)
      .attr('fill', 'none')
      .attr('stroke', 'rgba(255,255,255,0.35)')
      .attr('stroke-width', 1);

    // Solid dot
    cityG.append('circle')
      .attr('cx', x).attr('cy', y).attr('r', 2.5)
      .attr('fill', 'white')
      .attr('filter', 'url(#map-glow)');
  });

  // Fade in once rendered
  svgEl.style.opacity = '1';
</script>
