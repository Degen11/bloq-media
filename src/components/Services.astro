---
interface Service {
  title: string;
  description: string;
  icon: string;
}

const services: Service[] = [
  {
    title: 'Content Strategy',
    description:
      "A clear editorial plan tailored to your audience, goals, and the platforms they use. We map out what to publish, where, and how to measure whether it's working.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
    </svg>`,
  },
  {
    title: 'Digital Marketing',
    description:
      "SEO, social, and targeted campaigns designed for the tech and blockchain audience. We get your brand in front of founders, investors, and early adopters — where they actually spend time.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
    </svg>`,
  },
  {
    title: 'News & Thought Leadership',
    description:
      "Original articles, market reports, and op-eds that earn attention rather than fill column inches. We help you say something worth reading — and build the credibility that comes with it.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h6m-6-4h.01" />
    </svg>`,
  },
];
---

<section id="services" class="py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-bloq-blue text-sm font-semibold uppercase tracking-widest mb-4">What We Offer</p>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900">Our Services</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="group flex flex-col p-8 rounded-2xl border border-gray-100 hover:border-bloq-navy/20 hover:shadow-xl hover:shadow-bloq-navy/8 transition-all duration-300">
          <div class="w-12 h-12 bg-bloq-blue/10 rounded-xl flex items-center justify-center text-bloq-navy group-hover:bg-bloq-navy group-hover:text-white transition-all duration-300 mb-6">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">{service.title}</h3>
          <p class="text-gray-500 leading-relaxed text-sm flex-1">{service.description}</p>
          <a
            href="#contact"
            class="mt-6 inline-flex items-center text-bloq-navy font-semibold text-sm hover:text-bloq-blue transition-colors"
          >
            Get in touch
            <svg class="ml-1.5 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>

  </div>
</section>
