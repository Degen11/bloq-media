---
const year = new Date().getFullYear();

const links = [
  { label: 'About', href: '#about' },
  { label: 'Why BLOQ', href: '#why' },
  { label: 'Services', href: '#services' },
  { label: 'Clients', href: '#clients' },
  { label: 'Articles', href: '#articles' },
];

const socials = [
  {
    label: 'X / Twitter',
    href: 'https://x.com/_BLOQMedia',
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/company/bloq-media/',
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    label: 'Medium',
    href: 'https://medium.com/@bloqmedia',
    icon: `<path d="M2.846 6.887c.03-.295-.083-.586-.303-.784l-2.24-2.7v-.403H7.26l5.378 11.795 4.728-11.795H24v.403l-1.917 1.837c-.165.126-.247.333-.213.538v13.498c-.034.204.048.411.213.537l1.87 1.837v.403h-9.41v-.403l1.937-1.88c.19-.19.19-.246.19-.537V8.608l-5.39 13.688h-.727L4.278 8.608v9.174c-.052.385.076.774.347 1.052l2.521 3.058v.404H0v-.404l2.521-3.058c.27-.279.39-.67.325-1.052V6.887z"/>`,
  },
];
---

<footer class="bg-gray-950 text-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-10">

      <div class="flex flex-col items-center md:items-start gap-4">
        <img src="/logo.png" alt="BLOQ Media" class="h-8 w-auto brightness-0 invert opacity-90" />
        <p class="text-gray-400 text-sm max-w-xs text-center md:text-left leading-relaxed">
          Shaping tech narratives in Southeast Asia through authoritative reporting and strategic content.
        </p>
        <div class="flex items-center gap-4 mt-1">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="text-gray-500 hover:text-white transition-colors duration-200"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <Fragment set:html={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <nav class="flex flex-wrap justify-center md:justify-end gap-x-8 gap-y-3">
        {links.map((link) => (
          <a href={link.href} class="text-gray-400 hover:text-white text-sm transition-colors duration-200">
            {link.label}
          </a>
        ))}
        <a href="mailto:degen@bloq.media" class="text-gray-400 hover:text-white text-sm transition-colors duration-200">
          Contact
        </a>
      </nav>

    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {year} BLOQ Media. All rights reserved.
      </p>
      <a href="mailto:degen@bloq.media" class="text-gray-500 hover:text-bloq-blue text-sm transition-colors duration-200">
        degen@bloq.media
      </a>
    </div>
  </div>
</footer>
