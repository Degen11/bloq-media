---
const year = new Date().getFullYear();

const links = [
  { label: 'About', href: '#about' },
  { label: 'Why BLOQ', href: '#why' },
  { label: 'Services', href: '#services' },
  { label: 'Clients', href: '#clients' },
  { label: 'Articles', href: '#articles' },
];

const socials = [
  {
    label: 'X / Twitter',
    href: 'https://x.com/_BLOQMedia',
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/company/bloq-media/',
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    label: 'Medium',
    href: 'https://medium.com/@bloqmedia',
    icon: `<path d="M2.846 6.887c.03-.295-.083-.586-.303-.784l-2.24-2.7v-.403H7.26l5.378 11.795 4.728-11.795H24v.403l-1.917 1.837c-.165.126-.247.333-.213.538v13.498c-.034.204.048.411.213.537l1.87 1.837v.403h-9.41v-.403l1.937-1.88c.19-.19.19-.246.19-.537V8.608l-5.39 13.688h-.727L4.278 8.608v9.174c-.052.385.076.774.347 1.052l2.521 3.058v.404H0v-.404l2.521-3.058c.27-.279.39-.67.325-1.052V6.887z"/>`,
  },
];
---

<footer class="bg-gray-950 text-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-10">

      <div class="flex flex-col items-center md:items-start gap-4">
        <img src="/logo.png" alt="BLOQ Media" class="h-8 w-auto brightness-0 invert opacity-90" />
        <p class="text-gray-400 text-sm max-w-xs text-center md:text-left leading-relaxed">
          Shaping tech narratives in Southeast Asia through authoritative reporting and strategic content.
        </p>
        <div class="flex items-center gap-4 mt-1">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="text-gray-500 hover:text-white transition-colors duration-200"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <Fragment set:html={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <nav class="flex flex-wrap justify-center md:justify-end gap-x-8 gap-y-3">
        {links.map((link) => (
          <a href={link.href} class="text-gray-400 hover:text-white text-sm transition-colors duration-200">
            {link.label}
          </a>
        ))}
        <a href="#contact" class="text-gray-400 hover:text-white text-sm transition-colors duration-200">
          Contact
        </a>
      </nav>

    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {year} BLOQ Media. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <button
          id="open-privacy"
          class="text-gray-500 hover:text-white text-sm transition-colors duration-200 underline-offset-2 hover:underline"
        >
          Privacy Policy
        </button>
        <button
          id="open-terms"
          class="text-gray-500 hover:text-white text-sm transition-colors duration-200 underline-offset-2 hover:underline"
        >
          Terms of Service
        </button>
      </div>
    </div>
  </div>
</footer>

<!-- Privacy Policy Modal -->
<dialog id="privacy-modal" aria-labelledby="privacy-title" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-header">
      <h2 id="privacy-title" class="text-xl font-bold text-gray-900">Privacy Policy</h2>
      <button class="modal-close" aria-label="Close privacy policy">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <p class="text-sm text-gray-500 mb-6">Last updated: April 2026</p>

      <h3>Information We Collect</h3>
      <p>When you contact us through our website, we collect the information you provide: your name, email address, company name, and message. We also collect anonymous analytics data through Vercel Analytics to understand how visitors use our site.</p>

      <h3>How We Use Your Information</h3>
      <ul>
        <li>To respond to your enquiries and provide our services</li>
        <li>To improve our website and user experience</li>
        <li>To send relevant information about our services, where you have consented</li>
      </ul>
      <p>We do not sell, trade, or otherwise transfer your personal information to third parties without your consent, except as described below.</p>

      <h3>Third-Party Services</h3>
      <ul>
        <li><strong>Vercel Analytics</strong>: We use Vercel Analytics to collect anonymous, aggregated usage data. No personally identifiable information is shared with Vercel for analytics purposes.</li>
        <li><strong>Web3Forms / Resend</strong>: Contact form submissions are processed through these services solely to deliver your message to our team. Your data is not used by these services for any other purpose.</li>
        <li><strong>Google Fonts</strong>: We load the Inter typeface from Google Fonts. Google may collect limited usage data as part of this service.</li>
      </ul>

      <h3>Data Retention</h3>
      <p>We retain contact form submissions for as long as necessary to respond to your enquiry and for legitimate business record-keeping purposes, typically no longer than 2 years.</p>

      <h3>Your Rights</h3>
      <p>Depending on your jurisdiction, you may have the right to access, correct, delete, or restrict processing of your personal data. To exercise these rights, contact us at <a href="mailto:degen@bloq.media">degen@bloq.media</a>.</p>

      <h3>Cookies</h3>
      <p>Our website uses minimal, functional cookies required for site operation. Analytics data collected by Vercel Analytics is anonymous and does not use tracking cookies.</p>

      <h3>Governing Law</h3>
      <p>This Privacy Policy is governed by the laws of Singapore. Any disputes arising from this policy shall be subject to the exclusive jurisdiction of the courts of Singapore.</p>

      <h3>Contact</h3>
      <p>For any privacy-related questions, please contact us at <a href="mailto:degen@bloq.media">degen@bloq.media</a>.</p>
    </div>
  </div>
</dialog>

<!-- Terms of Service Modal -->
<dialog id="terms-modal" aria-labelledby="terms-title" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-header">
      <h2 id="terms-title" class="text-xl font-bold text-gray-900">Terms of Service</h2>
      <button class="modal-close" aria-label="Close terms of service">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <p class="text-sm text-gray-500 mb-6">Last updated: April 2026</p>

      <h3>Acceptance of Terms</h3>
      <p>By accessing and using bloq.media, you accept and agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website.</p>

      <h3>Services</h3>
      <p>BLOQ Media provides news reporting, content creation, and digital marketing services specialising in tech and blockchain in Southeast Asia. The information on this website is provided for general informational purposes only.</p>

      <h3>Intellectual Property</h3>
      <p>All content on this website — including text, graphics, logos, and images — is the property of BLOQ Media and is protected by applicable copyright and intellectual property laws. You may not reproduce, distribute, or create derivative works from our content without prior written permission.</p>

      <h3>User Conduct</h3>
      <p>You agree not to use our website to:</p>
      <ul>
        <li>Transmit any unlawful, harmful, or objectionable content</li>
        <li>Attempt to gain unauthorised access to any part of our systems</li>
        <li>Engage in any conduct that could damage, disable, or impair our services</li>
      </ul>

      <h3>Disclaimer of Warranties</h3>
      <p>Our website and its content are provided on an "as is" basis without any warranties, express or implied. BLOQ Media does not warrant that the website will be uninterrupted, error-free, or free of viruses or other harmful components.</p>

      <h3>Limitation of Liability</h3>
      <p>To the fullest extent permitted by law, BLOQ Media shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of, or inability to use, this website or its content.</p>

      <h3>Third-Party Links</h3>
      <p>Our website may contain links to third-party websites. These links are provided for your convenience only. BLOQ Media has no control over the content of those sites and accepts no responsibility for them.</p>

      <h3>Changes to Terms</h3>
      <p>We reserve the right to modify these terms at any time. Changes will be effective immediately upon posting. Your continued use of the website constitutes acceptance of the revised terms.</p>

      <h3>Governing Law</h3>
      <p>These Terms of Service are governed by the laws of Singapore. Any disputes arising from these terms shall be subject to the exclusive jurisdiction of the courts of Singapore.</p>

      <h3>Contact</h3>
      <p>For any questions about these terms, please contact us at <a href="mailto:degen@bloq.media">degen@bloq.media</a>.</p>
    </div>
  </div>
</dialog>

<script>
  function openModal(id: string) {
    (document.getElementById(id) as HTMLDialogElement | null)?.showModal();
  }

  function bindClose(modalId: string) {
    const dialog = document.getElementById(modalId) as HTMLDialogElement | null;
    if (!dialog) return;
    dialog.querySelector('.modal-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  document.getElementById('open-privacy')?.addEventListener('click', () => openModal('privacy-modal'));
  document.getElementById('open-terms')?.addEventListener('click', () => openModal('terms-modal'));
  bindClose('privacy-modal');
  bindClose('terms-modal');
</script>
