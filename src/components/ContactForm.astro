---
const socials = [
  {
    label: 'X / Twitter',
    href: 'https://x.com/_BLOQMedia',
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/company/bloq-media/',
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    label: 'Medium',
    href: 'https://medium.com/@bloqmedia',
    icon: `<path d="M2.846 6.887c.03-.295-.083-.586-.303-.784l-2.24-2.7v-.403H7.26l5.378 11.795 4.728-11.795H24v.403l-1.917 1.837c-.165.126-.247.333-.213.538v13.498c-.034.204.048.411.213.537l1.87 1.837v.403h-9.41v-.403l1.937-1.88c.19-.19.19-.246.19-.537V8.608l-5.39 13.688h-.727L4.278 8.608v9.174c-.052.385.076.774.347 1.052l2.521 3.058v.404H0v-.404l2.521-3.058c.27-.279.39-.67.325-1.052V6.887z"/>`,
  },
];

const inputClass = "w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:ring-2 focus:ring-bloq-blue focus:border-transparent transition-shadow";
---

<section id="contact" class="py-28 bg-gradient-to-br from-bloq-dark via-bloq-navy to-bloq-navy relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-10">
    <div class="absolute -top-32 -right-32 w-[600px] h-[600px] bg-bloq-blue rounded-full blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 w-[600px] h-[600px] bg-bloq-blue rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: copy + contact details -->
      <div class="lg:pt-6">
        <p class="text-bloq-blue text-sm font-semibold uppercase tracking-widest mb-4">Get in Touch</p>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
          Ready to make an impact?
        </h2>
        <p class="text-lg text-white/60 leading-relaxed mb-10">
          Whether you need a news partner, a content studio, or a full campaign — we're ready to talk.
        </p>

        <div class="flex items-center gap-3">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="w-10 h-10 bg-white/10 hover:bg-bloq-blue rounded-xl flex items-center justify-center transition-colors duration-200"
            >
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <Fragment set:html={s.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Right: form card -->
      <div class="bg-white rounded-2xl p-8 shadow-2xl shadow-black/25">

        <!-- Form -->
        <form id="contact-form" novalidate>

          <div class="flex flex-col gap-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">
                  Name <span class="text-bloq-blue">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Jane Smith"
                  class={inputClass}
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
                  Email <span class="text-bloq-blue">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="jane@company.com"
                  class={inputClass}
                />
              </div>
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 mb-1.5">
                Company <span class="text-gray-400 font-normal">(optional)</span>
              </label>
              <input
                type="text"
                id="company"
                name="company"
                autocomplete="organization"
                placeholder="Your company"
                class={inputClass}
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">
                Message <span class="text-bloq-blue">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell us about your project or what you're looking for…"
                class={`${inputClass} resize-none`}
              ></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full bg-bloq-navy text-white py-3.5 rounded-xl font-semibold text-sm hover:bg-bloq-dark transition-colors duration-200 flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed"
            >
              <span id="btn-label">Send Message</span>
              <svg id="btn-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
              <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z" />
              </svg>
            </button>
          </div>

          <!-- Inline error -->
          <div id="form-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            Something went wrong. Please try again or reach us directly on social media.
          </div>
        </form>

        <!-- Success state (replaces form) -->
        <div id="form-success" class="hidden py-6 text-center">
          <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Message sent!</h3>
          <p class="text-gray-500 text-sm">Thanks for reaching out — we'll be in touch shortly.</p>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnLabel = document.getElementById('btn-label');
  const btnArrow = document.getElementById('btn-arrow');
  const btnSpinner = document.getElementById('btn-spinner');
  const formError = document.getElementById('form-error');
  const formSuccess = document.getElementById('form-success');

  function setLoading(loading: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    btnLabel!.textContent = loading ? 'Sending…' : 'Send Message';
    btnArrow?.classList.toggle('hidden', loading);
    btnSpinner?.classList.toggle('hidden', !loading);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    formError?.classList.add('hidden');
    setLoading(true);

    const fd = new FormData(form);
    const body = {
      name: fd.get('name'),
      email: fd.get('email'),
      company: fd.get('company'),
      message: fd.get('message'),
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await res.json();

      if (data.success) {
        form.classList.add('hidden');
        formSuccess?.classList.remove('hidden');
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      formError?.classList.remove('hidden');
      setLoading(false);
    }
  });
</script>
