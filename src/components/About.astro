---
interface Pillar {
  title: string;
  description: string;
  icon: string;
}

const pillars: Pillar[] = [
  {
    title: 'Inform',
    description: "Authoritative reporting and in-depth analysis on the technologies shaping Southeast Asia's future.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h6m-6-4h.01" />
    </svg>`,
  },
  {
    title: 'Inspire',
    description: "Share your brand's vision with impactful storytelling that resonates in the region.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
    </svg>`,
  },
  {
    title: 'Engage',
    description: 'Build a dedicated audience through strategic content that drives conversations.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
    </svg>`,
  },
];
---

<section id="about" class="py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <div data-animate>
        <p class="text-bloq-blue text-sm font-semibold uppercase tracking-widest mb-4">About BLOQ Media</p>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6">
          The news org and content studio for Southeast Asia's tech scene.
        </h2>
        <p class="text-lg text-gray-500 leading-relaxed">
          Southeast Asia's tech and blockchain sector moves fast and speaks in jargon. BLOQ Media cuts through — with journalism that informs, stories that inspire, and content that engages.
        </p>
      </div>

      <div class="flex flex-col gap-5">
        {pillars.map((pillar, i) => (
          <div
            data-animate
            style={i > 0 ? `transition-delay: ${i * 100}ms` : undefined}
            class="group flex gap-5 p-6 rounded-2xl border border-gray-100 hover:border-bloq-blue/30 hover:shadow-lg hover:shadow-bloq-navy/5 transition-all duration-300"
          >
            <div class="flex-shrink-0 w-11 h-11 bg-bloq-navy/8 group-hover:bg-bloq-navy rounded-xl flex items-center justify-center text-bloq-navy group-hover:text-white transition-all duration-300">
              <Fragment set:html={pillar.icon} />
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-1">{pillar.title}</h3>
              <p class="text-gray-500 leading-relaxed text-sm">{pillar.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
